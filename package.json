{
  "name": "@12og3r/openctx",
  "version": "0.3.0",
  "description": "Browse local Claude Code session history in a TUI.",
  "keywords": [
    "claude",
    "claude-code",
    "tui",
    "cli",
    "session",
    "history",
    "ink"
  ],
  "homepage": "https://github.com/12og3r/open-context-cli#readme",
  "bugs": {
    "url": "https://github.com/12og3r/open-context-cli/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/12og3r/open-context-cli.git"
  },
  "license": "GPL-3.0-only",
  "author": "Roger <a550279039@gmail.com>",
  "type": "module",
  "bin": {
    "openctx": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "bun run build && node dist/cli.js",
    "dev:bun": "NODE_ENV=production bun run src/cli.tsx",
    "build": "bun build src/cli.tsx --outdir dist --target node --format esm --packages external",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "bun run build && chmod +x dist/cli.js"
  },
  "dependencies": {
    "@lydell/node-pty": "^1.2.0-beta.12",
    "emoji-regex": "^10.0.0",
    "ink": "^5.0.1",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "marked": "^12.0.0",
    "react": "^18.3.1",
    "string-width": "^7.2.0",
    "wrap-ansi": "^10.0.0"
  },
  "optionalDependencies": {
    "bun-pty": "^0.4.8"
  },
  "devDependencies": {
    "@types/bun": "^1.1.0",
    "@types/react": "^18.3.0",
    "ink-testing-library": "^4.0.0",
    "typescript": "^5.5.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
