{
  "name": "claude-history-cli",
  "version": "0.0.1",
  "private": true,
  "description": "Browse local Claude Code session history in a TUI.",
  "type": "module",
  "bin": {
    "claude-history": "./dist/cli.js"
  },
  "scripts": {
    "dev": "bun run src/cli.tsx",
    "build": "bun build src/cli.tsx --outdir dist --target node --format esm --packages external",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "ink": "^5.0.1",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "marked": "^12.0.0",
    "react": "^18.3.1",
    "string-width": "^7.2.0"
  },
  "devDependencies": {
    "@types/bun": "^1.1.0",
    "@types/react": "^18.3.0",
    "ink-testing-library": "^4.0.0",
    "typescript": "^5.5.0"
  }
}
